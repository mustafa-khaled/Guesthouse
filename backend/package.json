{
  "name": "guesthouse-backend",
  "version": "1.0.0",
  "description": "Guesthouse Booking & Management System API",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "ts-node-dev --transpile-only src/seeds/seed.ts",
    "seed:clean": "ts-node-dev --transpile-only src/seeds/seed.ts --clean",
    "seed:users": "ts-node-dev --transpile-only src/seeds/seed.ts --users",
    "seed:properties": "ts-node-dev --transpile-only src/seeds/seed.ts --properties --room-types --rooms --rate-plans --add-ons"
  },
  "keywords": [
    "guesthouse",
    "booking",
    "express",
    "api"
  ],
  "author": "mustafa-khaled",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "eventemitter2": "^6.4.9",
    "express": "^4.22.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.0",
    "multer": "^2.2.0",
    "nanoid": "^3.3.7",
    "nodemailer": "^8.0.11",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "stripe": "^14.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.6",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^3.2.4",
    "mongodb-memory-server": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
