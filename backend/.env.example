# ============================================
# Environment Configuration
# ============================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ============================================
# Database
# ============================================
MONGODB_URI=mongodb://localhost:27017/guesthouse

# Docker: Use this format when running with docker-compose
# MONGODB_URI=mongodb://admin:password@mongodb:27017/guesthouse?authSource=admin

# ============================================
# Redis (for caching and job queues)
# ============================================
REDIS_URL=redis://localhost:6379

# Docker: Use this format when running with docker-compose
# REDIS_URL=redis://redis:6379

# ============================================
# Authentication
# ============================================
JWT_ACCESS_SECRET=your-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long

# ============================================
# URLs
# ============================================
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_EMAIL_FROM="Guesthouse <no-reply@guesthouse.com>"

# ============================================
# Stripe Payments
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ============================================
# Cloudinary (Image Uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Audit Log
# ============================================
AUDIT_LOG_RETENTION_DAYS=90

# ============================================
# Docker Compose Variables (only used with docker-compose)
# ============================================
# MONGO_ROOT_USERNAME=admin
# MONGO_ROOT_PASSWORD=password