# ============================================
# Docker Compose Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# General
# ============================================
NODE_ENV=production

# ============================================
# MongoDB (Docker)
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-this-secure-password

# ============================================
# Authentication
# ============================================
JWT_ACCESS_SECRET=your-access-secret-at-least-32-characters-long-change-me
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long-change-me

# ============================================
# URLs
# ============================================
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Email (SMTP) - Optional
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_EMAIL_FROM=

# ============================================
# Stripe Payments - Optional
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Cloudinary (Image Uploads) - Optional
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
