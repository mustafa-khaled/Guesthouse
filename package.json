{
  "private": true,
  "scripts": {
    "dev": "concurrently -n sh,be,fe -c yellow,blue,green \"pnpm --filter @guesthouse/shared dev\" \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter @guesthouse/shared build && pnpm -r --filter !@guesthouse/shared build",
    "typecheck": "pnpm -r typecheck",
    "dev:be": "pnpm --filter backend dev",
    "dev:fe": "pnpm --filter frontend dev"
  },
  "pnpm": {
    "approvedBuilds": [
      "sharp"
    ],
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
